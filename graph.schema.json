{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "adaptive-context-pruner-v2.0.0-graph-schema",
  "description": "Graph schema for adaptive-context-pruner v2.0.0 — generated by GOTSCS v4.3.0 N-JSON",
  "type": "object",
  "required": ["metadata", "nodes", "edges"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "skill_name",
        "version",
        "determinism_class",
        "total_nodes",
        "total_edges",
        "back_edges",
        "total_waves",
        "topology",
        "spawn_node_count",
        "max_concurrent_spawns_per_run",
        "sinks"
      ],
      "properties": {
        "skill_name": { "type": "string" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "determinism_class": {
          "type": "string",
          "enum": ["deterministic", "non-deterministic"]
        },
        "total_nodes": { "type": "integer", "minimum": 1 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "back_edges": { "type": "integer", "minimum": 0 },
        "total_waves": { "type": "integer", "minimum": 1 },
        "topology": { "type": "string" },
        "spawn_node_count": { "type": "integer", "minimum": 0 },
        "max_concurrent_spawns_per_run": { "type": "integer", "minimum": 0 },
        "produced_skill_edge_cap_normal": { "type": "integer" },
        "produced_skill_edge_cap_aggressive": { "type": "integer" },
        "produced_skill_edge_cap_complex": { "type": "integer" },
        "sinks": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "evolution_mode": {
          "type": "string",
          "enum": ["greenfield", "overlay", "evolve", "evolve-aggressive", "complex"]
        },
        "evolved_from_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "exec_type",
          "hat",
          "tier",
          "wave",
          "context_budget_lines",
          "scale_gates",
          "input_dependencies",
          "required_output_sections",
          "raises_signals",
          "ai_advantages_exploited",
          "super_human_unlocks",
          "halt_conditions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^N-[A-Z][A-Z0-9-]*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "DECOMPOSITION", "TAILOR", "XREF", "LATERAL",
              "DEFIXATION", "SIMULATION", "PRECISION", "ADVERSARIAL",
              "CONJECTURE", "AGGREGATION", "ROUTER", "SYNTHESIS",
              "VERIFIER", "ATTACKER", "FORMATTER", "GENERATOR",
              "EXPANSION", "INGEST", "CLASSIFIER", "GATE",
              "META-ANALYZER", "ANALYZER", "RECOVERY", "FILTER",
              "TRIAGE", "PLANNER", "PREFLIGHT", "ACTUATOR", "IO",
              "VALIDATOR", "SCORER", "PERSISTER", "REFINER"
            ]
          },
          "exec_type": {
            "type": "string",
            "enum": ["inline", "spawn"]
          },
          "hat": {
            "type": "string",
            "enum": [
              "extractor", "gate", "generator", "classifier", "filter",
              "cache", "scorer", "clusterer", "analyzer", "aggregator",
              "refiner", "verifier", "recovery", "formatter", "persister",
              "no-llm"
            ]
          },
          "tier": {
            "type": "string",
            "enum": ["model-large", "model-medium", "model-small", "no-llm"]
          },
          "wave": {
            "type": "integer",
            "minimum": 1
          },
          "context_budget_lines": {
            "type": "integer",
            "minimum": 1
          },
          "scale_gates": {
            "type": "object",
            "required": ["token_budget", "time_budget", "spawn_budget", "retry_budget"],
            "properties": {
              "token_budget": { "type": "integer", "minimum": 0 },
              "time_budget": { "type": "integer", "minimum": 0 },
              "spawn_budget": { "type": "integer", "minimum": 0 },
              "retry_budget": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          },
          "input_dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required_output_sections": {
            "type": "array",
            "items": { "type": "string" }
          },
          "raises_signals": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ai_advantages_exploited": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "parallel_artifact_processing",
                "full_corpus_retention",
                "cross_document_pattern_recognition",
                "multi_perspective_simulation",
                "consistency_at_scale",
                "super_human_recall",
                "topology_aware_reasoning"
              ]
            },
            "minItems": 1
          },
          "super_human_unlocks": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "halt_conditions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "aggregation_policy": { "type": "string" },
          "join_policy": { "type": "string" },
          "context_source": {
            "type": "string",
            "enum": ["new", "preserved", "upgraded", "replaced", "merged", "removed", "resequenced", "recontracted"]
          },
          "context_rationale": { "type": "string" },
          "activation": { "type": "string" },
          "downshiftable": { "type": "boolean" },
          "scale_gate_annotation": { "type": "string" },
          "v16_resolution": { "type": "string" },
          "v16_note": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "target",
          "edge_type",
          "signal_field",
          "scale_gates"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^E-?[0-9]+[a-z]?$"
          },
          "source": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "target": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "edge_type": {
            "type": "string",
            "enum": [
              "required",
              "optional",
              "gate-open",
              "forward-conditional",
              "back-edge",
              "terminal"
            ]
          },
          "signal_field": { "type": "string" },
          "scale_gates": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 4,
            "maxItems": 4
          },
          "gate_condition": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "cap": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
